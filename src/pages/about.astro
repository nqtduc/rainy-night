---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout active="about" title="About">
  <section class="wrap about">
    <h1>About</h1>
    <p>
      I'm Duc. I take pictures of places that make me pause, and I write small
      stories to go with them — some true, some invented.
    </p>
    <p>
      This site is a slow, personal archive. No ads, no noise. Just scenery and
      a few words. Thanks for stopping by.
    </p>
    <a class="back" href="/">← Back home</a>
  </section>
</BaseLayout>
