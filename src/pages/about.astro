---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout active="about" title="About" description="About Rainy Night and the person behind it.">
  <section class="wrap-text about">
    <p class="kicker slate">Colophon</p>
    <h1>About</h1>
    <p class="lead">
      I'm Duc. I photograph places that make me pause, and I write small stories
      to keep them company — some true, some invented.
    </p>
    <p>
      Rainy Night is a slow, personal archive kept from Hanoi. No ads, no noise.
      Just scenery and a few words, best read late, with the lights low.
    </p>
    <p>
      Everything here is shot and written by me. If something made you feel
      something, that's the whole point. Thanks for stopping by.
    </p>
    <a class="back" href="/">← Back home</a>
  </section>
</BaseLayout>
